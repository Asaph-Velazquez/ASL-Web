# ============================================
# Server Configuration
# ============================================
# Puerto en el que se ejecutará el servidor WebSocket
PORT=3001

# ============================================
# Database Configuration
# ============================================
# URI de conexión a MongoDB
# Local: mongodb://localhost:27017/asl-hotel
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/asl-hotel
MONGODB_URI=mongodb://localhost:27017/asl-hotel

# ============================================
# JWT Configuration
# ============================================
# Clave secreta para firmar y verificar JWT tokens
# IMPORTANTE: Cambiar en producción por una clave segura y única
# Generar una: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production
